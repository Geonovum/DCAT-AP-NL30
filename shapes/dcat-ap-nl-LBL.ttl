###########################################
#  dcat:Dataset
###########################################

dcatapnl-sh:DatasetShape 
    sh:targetClass dcat:Dataset;
    rdfs:label "Dataset"@en, "Dataset"@nl;
    sh:property
        dcatapnl-sh:DatasetShape_description ,
        dcatapnl-sh:DatasetShape_title ,
        dcatapnl-sh:DatasetShape_contactPoint ,
        dcatapnl-sh:DatasetShape_distribution ,
        dcatapnl-sh:DatasetShape_spatial ,
        dcatapnl-sh:DatasetShape_keyword ,
        dcatapnl-sh:DatasetShape_publisher ,
        dcatapnl-sh:DatasetShape_temporal ,
        dcatapnl-sh:DatasetShape_theme ,
        dcatapnl-sh:DatasetShape_accessRights ,
        dcatapnl-sh:DatasetShape_applicableLegislation ,
        dcatapnl-sh:DatasetShape_conformsTo ,
        dcatapnl-sh:DatasetShape_creator ,
        dcatapnl-sh:DatasetShape_accrualPeriodicity ,
        dcatapnl-sh:DatasetShape_hasVersion ,
        dcatapnl-sh:DatasetShape_identifier ,
        dcatapnl-sh:DatasetShape_inSeries ,
        dcatapnl-sh:DatasetShape_isReferencedBy ,
        dcatapnl-sh:DatasetShape_landingPage ,
        dcatapnl-sh:DatasetShape_language ,
        dcatapnl-sh:DatasetShape_modified ,
        dcatapnl-sh:DatasetShape_other_identifier ,
        dcatapnl-sh:DatasetShape_provenance ,
        dcatapnl-sh:DatasetShape_qualifiedAttribution ,
        dcatapnl-sh:DatasetShape_qualifiedRelation ,
        dcatapnl-sh:DatasetShape_relation ,
        dcatapnl-sh:DatasetShape_issued ,
        dcatapnl-sh:DatasetShape_sample ,
        dcatapnl-sh:DatasetShape_source ,
        dcatapnl-sh:DatasetShape_spatialResolutionInMeters ,
        dcatapnl-sh:DatasetShape_temporalResolution ,
        dcatapnl-sh:DatasetShape_type ,
        dcatapnl-sh:DatasetShape_version ,
        dcatapnl-sh:DatasetShape_versionNotes ,
        dcatapnl-sh:DatasetShape_wasGeneratedBy ,
        dcatapnl-sh:DatasetShape_hvdCategory ,
        dcatapnl-sh:DatasetShape_documentation
.

dcatapnl-sh:DatasetShape_description
    sh:path dct:description;
    rdfs:label "description"@en, "beschrijving"@nl .

